# ═══════════════════════════════════════════════════
#  MEGAN AI Assistant — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# ─── Required: Google Gemini AI ────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# ─── Gemini Model Selection ────────────────────────
# Options: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash
MAX_TOKENS=2048

# ─── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database ──────────────────────────────────────
# Leave blank to use default (megan_memory.db in project root)
DATABASE_PATH=

# ─── Browser Agent ─────────────────────────────────
# Chrome must be started with: chrome.exe --remote-debugging-port=9222
BROWSER_PORT=9222

# ─── Voice Settings ─────────────────────────────────
# Female neural voice via edge-tts (Microsoft Neural TTS - free)
# Available female voices:
#   en-US-AriaNeural   (US, warm & natural — recommended)
#   en-US-JennyNeural  (US, clear & friendly)
#   en-GB-SoniaNeural  (British, elegant)
#   en-AU-NatashaNeural (Australian, upbeat)
VOICE_NAME=en-US-AriaNeural
VOICE_LANGUAGE=en-US
VOICE_RATE=+0%
VOICE_PITCH=+0Hz

# ─── Email (for Messaging Agent) ────────────────────
# Use a Gmail App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
MEGAN_EMAIL_ADDRESS=your_email@gmail.com
MEGAN_EMAIL_PASSWORD=your_app_password_here
