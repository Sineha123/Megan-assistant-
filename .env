# ─── Google Gemini AI ──────────────────────────────
GEMINI_API_KEY=AIzaSyAsSKgx3oDZqRJTuJTh9sj70KdhAnPqeDE
GEMINI_MODEL=gemini-2.5-flash
MAX_TOKENS=2048

# ─── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database ──────────────────────────────────────
DATABASE_PATH=

# ─── Browser Agent ─────────────────────────────────
BROWSER_PORT=9222

# ─── Voice — Hindi Female Neural Voice ─────────────
# hi-IN-SwaraNeural   -> Authentic Hindi female (Swara) — PRIMARY
# hi-IN-AnanyaNeural  -> Hindi female (Ananya) — alternative
# en-IN-NeerjaNeural  -> Indian-English female (Hinglish friendly)
VOICE_NAME=hi-IN-SwaraNeural
VOICE_LANGUAGE=hi-IN
VOICE_RATE=+0%
VOICE_PITCH=+5Hz

# ─── Response Language ─────────────────────────────
# hinglish = Roman Hindi + English mixed (default for MEGAN)
RESPONSE_LANGUAGE=hinglish

# ─── STT Language ──────────────────────────────────
# hi-IN accepts both Hindi and code-switched Hinglish
STT_LANGUAGE=hi-IN

# ─── Email ─────────────────────────────────────────
MEGAN_EMAIL_ADDRESS=
MEGAN_EMAIL_PASSWORD=
